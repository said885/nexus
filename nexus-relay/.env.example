# NEXUS Relay Server Configuration
# Copy to .env and customize for your environment

# ==============================================================================
# Server Configuration
# ==============================================================================
NEXUS_HOST=0.0.0.0
NEXUS_PORT=3000
RUST_LOG=nexus_relay=info,tower_http=warn,axum=warn

# ==============================================================================
# Database Configuration
# ==============================================================================
DATABASE_URL=postgres://nexus:nexus-secure-pwd-change-me@postgres:5432/nexus
DB_PASSWORD=nexus-secure-pwd-change-me

# ==============================================================================
# Redis Configuration
# ==============================================================================
REDIS_URL=redis://:nexus-redis-pwd@redis:6379
REDIS_PASSWORD=nexus-redis-pwd

# ==============================================================================
# TLS/SSL Configuration
# ==============================================================================
TLS_CERT_PATH=/etc/nexus/certs/certificate.pem
TLS_KEY_PATH=/etc/nexus/certs/key.pem

# ==============================================================================
# Metrics Configuration
# ==============================================================================
METRICS_PORT=9090
ENABLE_METRICS=true

# ==============================================================================
# Monitoring / Observability
# ==============================================================================
GRAFANA_PASSWORD=admin-change-me
PGADMIN_PASSWORD=admin

# ==============================================================================
# Application Settings
# ==============================================================================
# Message max size (bytes)
MAX_MESSAGE_SIZE=65536

# Message retention (days)
MESSAGE_RETENTION_DAYS=90

# Offline message cleanup interval (hours)
CLEANUP_INTERVAL_HOURS=24

# ==============================================================================
# Security Settings
# ==============================================================================
# Rate limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECS=60

# Brute force protection
BRUTE_FORCE_THRESHOLD=5
BRUTE_FORCE_LOCKOUT_MINS=60

# Session timeout (seconds)
SESSION_TIMEOUT_SECS=86400

# ==============================================================================
# Privacy Settings
# ==============================================================================
# Metadata privacy level: public, minimal, almostzero, zeroknowledge
METADATA_PRIVACY_LEVEL=almostzero

# Differential privacy epsilon (lower = more private, less accurate)
DP_EPSILON=0.5

# ==============================================================================
# Persistence Settings
# ==============================================================================
# Connection pool size
DB_POOL_SIZE=20

# Redis database index
REDIS_DB=0
